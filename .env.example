# ============================================================
# Desperately Seeking — environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# Node / runtime
NODE_ENV=development
PORT=3000

# ============================================================
# Site URLs (single source of truth)
# ------------------------------------------------------------
# PAYLOAD_PUBLIC_SITE_URL is read first by getSiteUrl() and used
# in sitemap, robots.txt, all canonical/OG URLs.
# ============================================================
PAYLOAD_PUBLIC_SITE_URL=https://desperatelyseeking.xyz
NEXT_PUBLIC_SERVER_URL=https://desperatelyseeking.xyz
PAYLOAD_PUBLIC_SERVER_URL=https://desperatelyseeking.xyz
CORS_ORIGIN=https://desperatelyseeking.xyz

# ============================================================
# Database
# ============================================================
DATABASE_URI=postgres://USER:PASSWORD@HOST:5432/DBNAME
PAYLOAD_SECRET=change-me-to-a-long-random-string

# ============================================================
# On-demand revalidation
# ------------------------------------------------------------
# REVALIDATE_SECRET protects the /api/revalidate endpoint.
# Generate with: openssl rand -hex 32
# Without this set, /api/revalidate refuses all requests with 503.
# ============================================================
REVALIDATE_SECRET=change-me-to-a-long-random-string

# ============================================================
# Email (Resend)
# ============================================================
RESEND_API_KEY=re_xxx
CONTACT_EMAIL=info@desperatelyseeking.xyz
FROM_EMAIL=noreply@desperatelyseeking.xyz

# ============================================================
# Google services
# ============================================================
GOOGLE_PLACES_API_KEY=AIzaSy...
GOOGLE_PLACE_ID=ChIJ...
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# ============================================================
# Dev-only
# ============================================================
DISABLE_PAYLOAD_HMR=false

# Serve media from the production server instead of local disk.
# Set this ONLY in local dev when using the production database but the
# uploaded files are not synced to the local media/ folder.
# NEVER set in production.
# MEDIA_BASE_URL=https://desperatelyseeking.xyz
